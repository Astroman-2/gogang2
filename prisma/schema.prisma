generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Post {
  id        Int       @id @default(autoincrement())
  title     String
  lyrics    String
  imageUrl  String
  ytUrl     String
  createdAt DateTime  @default(now())
  comments  Comment[]
  reactions Reaction[]
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  author    String   @default("Anonymous")
  postId    Int
  post      Post     @relation(fields: [postId], references: [id])
  createdAt DateTime @default(now())
}

model Reaction {
  id     Int    @id @default(autoincrement())
  type   String
  count  Int    @default(0)
  postId Int
  post   Post   @relation(fields: [postId], references: [id])
}